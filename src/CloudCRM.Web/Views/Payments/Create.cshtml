@model CloudCRM.Web.Models.ViewModels.PaymentViewModel

<h2>Create Payment</h2>

<form asp-action="Create"
      method="post">

    <div class="mb-3">

        <label asp-for="MembershipId"></label>

        <select asp-for="MembershipId"
                asp-items="Model.Memberships"
                class="form-select">

            <option value="">
                Select Membership
            </option>

        </select>

    </div>

    <div class="mb-3">

        <label asp-for="Amount"></label>

        <input asp-for="Amount"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label asp-for="PaymentDate"></label>

        <input asp-for="PaymentDate"
               type="date"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label asp-for="PaymentMethod"></label>

        <input asp-for="PaymentMethod"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label asp-for="TransactionReference"></label>

        <input asp-for="TransactionReference"
               class="form-control" />

    </div>

    <button type="submit"
            class="btn btn-primary">

        Save

    </button>

    <a asp-action="Index"
       class="btn btn-secondary">

        Cancel

    </a>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}