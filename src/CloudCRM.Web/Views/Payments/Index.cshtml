@model IEnumerable<CloudCRM.Core.Entities.Payment>

@{
    ViewData["Title"] = "Payments";
}

<h2 class="mb-4 fw-bold">Payments</h2>

<p>
    <a asp-action="Create"
       class="btn btn-primary mb-3">
        Create Payment
    </a>
</p>

<table class="table table-hover table-striped align-middle shadow-sm">

    <thead>
        <tr>
            <th>Customer</th>
            <th>Amount</th>
            <th>Payment Date</th>
            <th>Payment Method</th>
            <th>Transaction Reference</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.Membership.Customer.FirstName
                    @item.Membership.Customer.LastName
                </td>

                <td>
                    £@item.Amount.ToString("N2")
                </td>

                <td>
                    @item.PaymentDate.ToShortDateString()
                </td>

                <td>
                    @item.PaymentMethod
                </td>

                <td>
                    @item.TransactionReference
                </td>

                <td>
                    <a asp-action="Edit"
                        asp-route-id="@item.Id"
                        class="btn btn-outline-primary btn-sm">
                        Edit
                    </a>
                    <a asp-action="Delete"
                        asp-route-id="@item.Id"
                        class="btn btn-outline-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }

    </tbody>

</table>