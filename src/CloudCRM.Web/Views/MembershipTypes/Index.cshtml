@model IEnumerable<CloudCRM.Core.Entities.MembershipType>

@{
    ViewData["Title"] = "Membership Types";
}

<h2 class="mb-4 fw-bold">Membership Types</h2>

<p>
    <a asp-action="Create" class="btn btn-primary mb-3">
        Create Membership Type
    </a>
</p>

<table class="table table-hover table-striped align-middle shadow-sm">

    <thead>
        <tr>
            <th>Name</th>
            <th>Duration</th>
            <th>Price</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

@foreach(var item in Model)
{
    <tr>
        <td>@item.Name</td>
        <td>@item.DurationInMonths</td>
        <td>@item.Price</td>
        <td>@item.Description</td>
        <td>
            <a asp-action="Edit"
                asp-route-id="@item.Id"
                class="btn btn-outline-primary btn-sm">
                    Edit
            </a>

            <a asp-action="Delete"
                asp-route-id="@item.Id"
                class="btn btn-outline-danger btn-sm">
                    Delete
            </a>
        </td>
    </tr>
}

    </tbody>

</table>