@model CloudCRM.Web.Models.ViewModels.MembershipViewModel

<h2>Edit Membership</h2>

<form asp-action="Edit" method="post">

    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="CustomerId"></label>

        <select asp-for="CustomerId"
                asp-items="Model.Customers"
                class="form-select">
            <option value="">Select Customer</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="MembershipTypeId"></label>

        <select asp-for="MembershipTypeId"
                asp-items="Model.MembershipTypes"
                class="form-select">
            <option value="">Select Membership Type</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate"></label>

        <input asp-for="StartDate"
               class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive"
               class="form-check-input" />

        <label asp-for="IsActive"
               class="form-check-label">
        </label>
    </div>

    <button type="submit"
            class="btn btn-primary">
        Save
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}