@model CloudCRM.Web.Models.ViewModels.MembershipViewModel

<h2>Create Membership</h2>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label asp-for="CustomerId"></label>
        <select asp-for="CustomerId"
                asp-items="Model.Customers"
                class="form-select">
            <option value="">Select Customer</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="MembershipTypeId"></label>
        <select asp-for="MembershipTypeId"
                asp-items="Model.MembershipTypes"
                class="form-select">
            <option value="">Select Membership Type</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">
        Save
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}